# Copy to .env and adjust. Never commit the real .env.
PORT=3000
NODE_ENV=development

# PostgreSQL + PostGIS
DATABASE_URL=postgres://parkingboss:parkingboss@localhost:5432/parkingboss

# CORS: comma-separated origins, or * for any (dev only)
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# OpenChargeMap API key (free, register at https://openchargemap.org/site/develop/api)
OCM_API_KEY=
